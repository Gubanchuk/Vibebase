# Copy to app/.env.local and fill in real values.
# The app/ directory is where Next.js reads env vars from.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── OpenAI ────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_DEFAULT=gpt-5.4
OPENAI_MODEL_CHEAP=gpt-5.4-mini

# ─── Feature flags ─────────────────────────────────────────────────────────
ENABLE_MISTAKE_TRACKING=false

# ─── Script-only (optional) ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# CRON_SECRET=
